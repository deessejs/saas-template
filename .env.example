# ============================================================================
# One source of truth for all env vars across the monorepo.
#
# Copy this file to `.env` at the repo root:
#   cp .env.example .env
#
# The schema is validated by `packages/env/src/schema.ts`. Anything missing or
# invalid fails fast at the first import of `@workspace/env/server`.
#
# Required:
#   - DATABASE_URL          Postgres connection string
#   - BETTER_AUTH_SECRET    >= 32 chars. Generate: openssl rand -base64 32
#
# Optional (defaults shown):
#   - BETTER_AUTH_URL       defaults to http://localhost:3000
#   - ALLOWED_ORIGINS       defaults to localhost:3000,localhost:3001
#   - TEST_DATABASE_URL     falls back to DATABASE_URL when unset
#   - AUTH_SECRET           alias for BETTER_AUTH_SECRET
#
# Client-safe (NEXT_PUBLIC_*) are inlined at build time into browser bundles.
# ============================================================================

# ============================================================================
# Database
# ============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/saas

# ============================================================================
# better-auth (server-side)
# ============================================================================
BETTER_AUTH_SECRET=                   # Run: openssl rand -base64 32
AUTH_SECRET=                          # Alias fallback for BETTER_AUTH_SECRET
BETTER_AUTH_URL=http://localhost:3000 # Origin of the Next.js server

# Comma-separated list of allowed CORS origins (including protocol)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================================================
# Client-side (NEXT_PUBLIC_* — safe to commit, values are public)
# ============================================================================
NEXT_PUBLIC_APP_NAME=SaaS Template
NEXT_PUBLIC_APP_DESCRIPTION=SaaS application built with Next.js and shared UI components
NEXT_PUBLIC_APP_URL=http://localhost:3000 # Must match BETTER_AUTH_URL in production

# ============================================================================
# Mailer (transport selector)
# ============================================================================
#   "console" (default) → logs to stdout, zero infrastructure
#   "resend"            → production, uses RESEND_API_KEY below
MAIL_TRANSPORT=console

# ============================================================================
# Mailer (Resend, production)
# ============================================================================
# Get an API key at https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME="SaaS Template"
