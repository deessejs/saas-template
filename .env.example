# ============================================================================
# Database
# ============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/saas

# ============================================================================
# better-auth (server-side)
# ============================================================================
BETTER_AUTH_SECRET=                   # Run: openssl rand -base64 32
AUTH_SECRET=                          # Alias fallback for BETTER_AUTH_SECRET
BETTER_AUTH_URL=http://localhost:3000 # Origin of the Next.js server

# Comma-separated list of allowed CORS origins (including protocol)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================================================
# Client-side (NEXT_PUBLIC_* — safe to commit, values are public)
# ============================================================================
NEXT_PUBLIC_APP_NAME=SaaS Template
NEXT_PUBLIC_APP_DESCRIPTION=SaaS application built with Next.js and shared UI components
NEXT_PUBLIC_APP_URL=http://localhost:3000 # Must match BETTER_AUTH_URL in production
