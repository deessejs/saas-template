{
  "extends": "@workspace/typescript-config/base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "isolatedDeclarations": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
